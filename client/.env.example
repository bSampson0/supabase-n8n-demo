# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (optional - leave empty for development, set in production)
# In development, Vite proxy handles /api requests to localhost:3001
# In production on Netlify, set this to your deployed server URL
# Example: https://devops-hub-server.onrender.com
VITE_API_URL=
